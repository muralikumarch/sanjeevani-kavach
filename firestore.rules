rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /children/{childId} {
      // Only authenticated users can read/write their children documents
      allow read, write: if request.auth != null;
    }

    match /vaccine_records/{recordId} {
      // Allow reading and writing records if user is logged in
      allow read, write: if request.auth != null;
    }
    
    match /sync_requests/{requestId} {
      allow read, write: if request.auth != null;
    }
  }
}
